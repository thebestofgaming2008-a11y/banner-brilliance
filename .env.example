# Public Vite values (embedded in the storefront build)
VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site
VITE_PUBLIC_SITE_URL=https://your-domain.example
VITE_STORE_NAME=Fawzaan
VITE_WHATSAPP_ORDER_PHONE=919152999764
VITE_RAZORPAY_KEY_ID=rzp_test_replace_me

# Convex production environment (set with `npx convex env set`)
ADMIN_EMAIL=owner@example.com
AUTH_SECRET=generate_a_long_random_secret
JWT_PRIVATE_KEY=replace_me
JWKS=replace_me
# CONVEX_SITE_URL is supplied automatically by Convex and cannot be overridden.
SITE_URL=https://your-domain.example
PUBLIC_SITE_URL=https://your-domain.example
ADMIN_UPLOAD_TOKEN=generate_a_long_random_secret
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_WEBHOOK_SECRET=replace_me
RESEND_API_KEY=re_replace_me
AUTH_EMAIL_FROM=Fawzaan <account@updates.your-domain.example>
MARKETING_FROM_EMAIL=Fawzaan <offers@updates.your-domain.example>
MARKETING_SECRET=generate_a_long_random_secret

# Cloudflare Pages server environment
EXCHANGE_RATE_API_KEY=replace_me

